# =============================================================================
# Yojimbo — Government AI Receptionist
# Environment Configuration Template
#
# Copy this file: cp .env.example .env
# Fill in your real secrets before starting the server.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=false
BASE_URL=https://your-domain.ngrok-free.app

# Secret key for session cookies and JWT token signing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite (default, single-instance deployments)
DATABASE_URL=sqlite+aiosqlite:///./yojimbo.db

# PostgreSQL (for multi-instance / production scaling)
# DATABASE_URL=postgresql+asyncpg://yojimbo:password@localhost:5432/yojimbo

# -----------------------------------------------------------------------------
# Twilio (required for phone calls and SMS)
# Get these from https://console.twilio.com
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Google Gemini AI (required for AI conversation)
# Get API key from https://aistudio.google.com
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.3

# Google Cloud (optional — for Translation API if not using native Gemini)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# -----------------------------------------------------------------------------
# ElevenLabs TTS (optional — higher-quality voice)
# Leave blank to use Twilio built-in TTS (free)
# Get API key from https://elevenlabs.io
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# -----------------------------------------------------------------------------
# ConversationRelay Settings
# -----------------------------------------------------------------------------
CR_TTS_PROVIDER=google
CR_STT_PROVIDER=google
CR_WELCOME_GREETING=Hello, thank you for calling. How can I help you today?

# -----------------------------------------------------------------------------
# Government Office
# -----------------------------------------------------------------------------
OFFICE_NAME=City Hall
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,zh,vi,ko,tl,ar,fr,de,ja
